{
  "manifest_version": 3,
  "name": "WeBWorKMAX",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "WeBWorKMAX Extension"
  },
  "permissions": ["activeTab", "storage", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://webwork3.charlotte.edu/webwork2/*/instructor/grader/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}